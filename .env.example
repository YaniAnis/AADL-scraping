# ─────────────────────────────────────────────
#  ⚙️  Configuration Email — Veille Immobilière
# ─────────────────────────────────────────────
# Copiez ce fichier en .env et remplissez vos identifiants :
#   cp .env.example .env
#
# Pour Gmail : Mon compte Google > Sécurité >
# Authentification 2 facteurs > Mots de passe d'application

EMAIL_EXPEDITEUR=votre_email@gmail.com
EMAIL_MOT_DE_PASSE=xxxx xxxx xxxx xxxx
EMAIL_DESTINATAIRE=votre_email@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
